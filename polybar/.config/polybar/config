[colors]
;background = ${xrdb:color0:#222}
background = #444
background-alt = #222
;foreground = ${xrdb:color7:#222}
foreground = #dfdfdf
foreground-alt = #555
primary = #ffb52a
secondary = #e60053
alert = #bd2c40
graphite = #2e3440
gray = #707f9c
green = #50fa7b
white = #ffffff


[bar/my_bar]
;monitor = ${env:MONITOR:HDMI-1}
monitor = ${env:MONITOR}
enable-ipc = true
width = 100%
height = 30
offset-x = 0
offset-y = 0
radius = 0
fixed-center = true

background = ${colors.graphite}
foreground = ${colors.white}

border-size = 3
border-color = ${colors.graphite}

module-margin-left = 1
module-margin-right = 1

font-0 = "Roboto,Roboto Medium:style=Medium,Regular:size=11;1"
font-1 = "Font Awesome 5 Free:style=Regular:size=12;1"
font-2 = "Font Awesome 5 Free:style=Solid:size=12;1"
font-3 = "Font Awesome 5 Brands:size=12;1"
font-4 = WunconSiji:pixelsize=10;0
font-5 = "unifont:size=12:antialias=false;0"
font-6 = "Unifont Upper:size=12:antialias=false;0"

modules-left = i3
modules-center = mpd mpv vpncheck redshift pkg
modules-right = filesystem memory cpu backlight volume xkeyboard battery wlan eth date

tray-position = center
tray-offset-x=279


[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix ="’ä£ "
format-prefix-foreground = ${colors.foreground-alt}
format-prefix-underline = ${colors.secondary}

label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
label-indicator-underline = ${colors.secondary}


[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted =’éĀ %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}


[module/memory]
type = internal/memory

; Seconds to sleep between updates
; Default: 1
interval = 3

format = <bar-used>
bar-used-indicator =
bar-used-width = 10
bar-used-foreground-0 = #55aa55
bar-used-foreground-1 = #557755
bar-used-foreground-2 = #f5a70a
bar-used-foreground-3 = #ff5555
bar-used-fill = Ō¢É
bar-used-empty = Ō¢É
bar-used-empty-foreground = #444444


[module/cpu]
type = internal/cpu

; Seconds to sleep between updates
; Default: 1
interval = 0.5
format = <ramp-coreload>
label = CPU %percentage%%

ramp-coreload-0 = Ō¢ü
ramp-coreload-1 = Ō¢é
