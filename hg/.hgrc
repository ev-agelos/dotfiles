[ui]
username = Evagelos Theodoridis <evagelos@softwear.nl>
ssh = ssh -C
merge = nvim

[extensions]
color =
graphlog =
progress =
pager =
onsub = ~/workspace/softwear.ci/dev/onsub.py
shelve = 
rebase =
strip =

[merge-tools]
nvim.executable = nvim
nvim.args = -f -d $output -M $local $base $other -c "wincmd J" -c "set modifiable" -c "set write"
nvim.premerge = keep

[alias]
lga = glog --style=~/dotfiles/hg-map-cmdline.lg
slog = log --style=$HOME/repos/mercurial-cli-templates/map-cmdline.slog
nlog = log --style=$HOME/repos/mercurial-cli-templates/map-cmdline.nlog
sglog = glog --style=$HOME/repos/mercurial-cli-templates/map-cmdline.sglog

[pager]
pager = LESS='FSRX' less
attend = cat, diff, glog, log, incoming, outgoing, lg, show, lga

