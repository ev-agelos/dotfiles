[user]
    email = evagelos.theo@gmail.com
    name = ev-agelos
[push]
	default = current
[difftool]
    prompt = false
    trustExitCode = true
[merge]
    ff = only
    tool = vimdiff
    conflictstyle = diff3
[alias]
    tree = log --oneline --graph --decorate --all
    l = log
    lg = log --oneline
    lgg = log --graph --branches --all --pretty=format:'%C(blue dim)%h%Creset -%C(auto)%d%C(reset) %s %C(blue dim)(%cr) %C(blue dim)<%an>%Creset' --abbrev-commit --date=relative
    lr = ! git log --oneline --color --pretty=format:'%C(auto)%d%C(white dim) %s' | nl | less -R
    difff = ! git diff | diff-so-fancy | less --tabs=4 -RFXS --pattern '^(Date|added|deleted|modified): '

    ci = commit
    d = !git --no-pager diff
    dc = !git --no-pager diff --cached
    s = status
    ss = status -s
    aa = add .
    sl = stash list
    ca = commit --amend --no-edit
    co = checkout
    rb = rebase

    branches = branch -a
    stashes = stash list
    unstage = reset -q HEAD --
    uncommit = reset --mixed HEAD~
    nevermind = !git reset --hard HEAD && git clean -d -f
[color]
    ui = auto
    diff = always
[color "diff"]
    meta = blue
    commit = green dim
    frag = magenta bold
    old = red dim
    new = green dim
    whitespace = red reverse
[rerere]
    enabled = false
[core]
	pager = diff-so-fancy | less --tabs=4 -RFXS --pattern '^(Date|added|deleted|modified): '
    excludesfile = $XDG_CONFIG_HOME/git/ignore_global
[color "diff-highlight"]
    oldNormal = red dim bold
    oldHighlight = red dim bold 52
    newNormal = green dim bold
    newHighlight = green dim bold 22
[mergetool]
    prompt = false
[mergetool "vimdiff"]
    cmd = nvim -d $LOCAL $REMOTE $MERGED -c '$wincmd w' -c 'wincmd J'
[diff-so-fancy]
	markEmptyLines = false
[pager]
    diff = false
